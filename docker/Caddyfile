{
	# FrankenPHP server with the PHP module loaded.
	frankenphp
	order php_server before file_server

	# Render terminates TLS at the edge — disable Caddy's own HTTPS handling.
	auto_https off
	admin off
	persist_config off

	# Structured logs to stderr for Render's log viewer.
	log {
		output stderr
		format console
		level INFO
	}
}

# Listen on Render's injected $PORT (defaults to 8080 locally — see Dockerfile).
:{$PORT} {
	root * /app/public

	encode zstd br gzip

	# Tell Laravel it's behind a proxy so generated URLs use https://.
	request_header X-Forwarded-Proto https

	# Long-lived caching for hashed Vite build assets.
	@buildAssets path /build/*
	header @buildAssets Cache-Control "public, max-age=31536000, immutable"

	# Serve static files directly, fall through to Laravel's front controller.
	php_server
}
